# ─── ScrumBoard Backend – Konfiguration ─────────────────────────────────────
# Kopiere diese Datei nach .env und passe die Werte an.

# Server
PORT=3001

# Basisverzeichnis für alle Scrum-Projekte auf diesem Rechner
PROJECTS_BASE_DIR=/home/user/ScrumProjects

# Port des Frontends (für CORS-Whitelist)
CLIENT_PORT=5173

# ─── LLM-Konfiguration ───────────────────────────────────────────────────────
# Priorität: OLLAMA_URL > OPENAI_API_KEY > GitHub Models (Standard)

# Modellname (für GitHub Models und OpenAI)
LLM_MODEL=gpt-4o-mini

# Pause zwischen LLM-Anfragen in Millisekunden (verhindert Rate-Limits)
# Standard: 5000 (5 Sekunden). Auf 0 setzen um die Pause zu deaktivieren.
LLM_DELAY_MS=5000

# GitHub Models via CLI statt REST API (benötigt: gh extension install github/gh-models)
# GH_CLI_MODE=1

# Option A: Ollama (lokal, kein API-Key nötig)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Option B: Anthropic (Fallback bei Rate Limits, z.B. claude-haiku-4-5-20251001)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Option C: OpenAI-kompatible API
# OPENAI_API_KEY=sk-...
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions
